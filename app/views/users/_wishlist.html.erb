<script> 
  reset_map_controllers();
  document.getElementById("page_status").innerHTML = '';
  document.body.classList.remove('loading');
</script>

<div id="actionbar" class="span7">
  <div id="crumbs">
    <%=link_to "Home", '/', remote: true,  :id => 'home', :onclick => "linkHandler('home')" %>
    &nbsp;--&gt;&nbsp;
    <%=  link_to  "Users", '/users', remote: true,  :id => 'users', :onclick => "linkHandler('users')" %>
    &nbsp;--&gt;&nbsp;
    <%= link_to @user.callsign.upcase, '/users/'+@user.callsign, remote: true,  :id => 'users', :onclick => "linkHandler('users')" %>
    &nbsp;--&gt;&nbsp;
    <b>Wishlist</b>
  </div>

  <div id="controls">
    <%=  link_to "Index", "/users", class: "btn btn-small btn-primary", remote: true,  :id => 'index', :onclick => "linkHandler('index')" %>
    <span id="layers_off"><%=  link_to "Hide layers", "#", class: "btn btn-small btn-primary",   :onclick => "site_set_map_filters('point',[]);site_refresh_layer('point');return false;"%></span>
    <span id="layers_on"><%=  link_to "Show layers", "#", class: "btn btn-small btn-primary",   :onclick => "site_set_map_filters('point',site_all_point_layers);site_refresh_layer('point');return false;"%></span>

    <%=render 'map_controls'%>
  </div>
</div>

<div id="right_scroll">
  <%= render 'flash' %>
  <div class="erow">
    <div class="sectiontitle" style="margin-top: 12px;">Wishlist</div>

    <table id="place_table">
      <% if @assets and @assets.count>0 %>
        <% @assets.each do |a| %>
          <tr>
            <td>
              <%=link_to a.codename, '/assets/'+a.safecode, remote: true,  :id => 'asset', :onclick => "linkHandler('asset')" %>
               <% if current_user and (current_user.is_admin or current_user.id == @user.id) %>
                 <%=  link_to "Remove", '/assets/'+a.safecode+'/remove_wish?referring=wishlist', class: "link_to", remote: true, :onclick => "linkHandler('dewish')" %>
               <% end %>
            </td>
          </tr>
        <% end %>
      </table>
    <% else %>
      <i> Your wishlist is empty.  Try adding some places to it!</i>
    <% end %>
  </div>
</div>

<script>
  document.getElementById('actionbar-full').innerHTML=document.getElementById('actionbar').innerHTML;

  <% if @assets then @assets.each do |asset| %>
      <% if asset.location then %> map_add_feature_from_wkt('<%=asset.location%>', 'EPSG:4326',site_green_circle); <% end %>
  <% end end %>

</script>

