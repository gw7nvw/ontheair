<script>
   document.getElementById("page_status").innerHTML = '';
   document.body.classList.remove('loading');
   document.title = <%= raw(@site_title) %>
   document.getElementById('logo').innerHTML = <%= raw(@site_title) %>
$(function () {
  $('#right_panel .pagination a').on('click', function () {
    $.getScript(this.href+"&sortby=<%=@sortby%>");
    return false;
  });
});

</script>

<div id="actionbar" class="span7">
   <div id="crumbs">
     Home
     &nbsp;--&gt;&nbsp;
     <b>IP Blocking</b>
   </div>
   <div id="controls">
     <%=render 'map_controls'%>
   </div>
</div>
<div id="right_scroll">
  <%= render 'flash' %>

  <h2>Tracked IPs</h2>
  <div class="erow">
    <div class="rowtitle">Stats:</div>
    <div class="rowtext">
      Tracked: <%= @count %>, Humans: <%= @humans %>, Robots: <%= @robots %>, Suspects: <%= @suspects %>
    </div>
  </div>
  
  <br/>
  <br/>
  <%= form_tag '/blocks', :name => 'findform', :remote => true, :method => 'get', :style => 'margin-bottom: 0px' %>
    <br/>

    <div class="rowtitle">Order:</div>
    <div class="rowtext">
      <%= collection_select :findform, :sort_order, ["total hits","suspicious hits"], :to_s, :to_s, { }  %>
    </div>

    <div class="rowtitle">Find:</div>
    <div class="rowtext">
      <input type="text" name="searchtext" id="searchtext" value='<%=@searchtext%>'/>
    </div>

    <div class="sectiontitle">Filters</div>
    <div class="erow">
        <div class="rowtitle">Human:</div>
      </span>
      <div class="rowtext">
<% puts "*********************** #{@human} *********************" %>

        <input id="human" name="human" type="checkbox" <%= if @human then 'checked="checked"' end%>/>
      </div>
    </div>
    <div class="erow">
        <div class="rowtitle">Bot:</div>
      </span>
      <div class="rowtext">
        <input id="robot" name="robot" type="checkbox" <%= if @robot then 'checked="checked"' end%>/>
      </div>
    </div>
    <div class="erow">
        <div class="rowtitle">Suspect:</div>
      </span>
      <div class="rowtext">
        <input id="suspect" name="suspect" type="checkbox"  <%= if @suspect then 'checked="checked"' end%>/>
      </div>
    </div>

    <div class="buttonshort">
      <%= submit_tag "Find", :id => "find", :class => "btn btn-small", :onclick => "submitHandler('Finding...');" %>
      <%= link_to "Clear", '/blocks', class: "btn btn-small", remote: true, :onclick => "linkHandler('clear')" %>
    </div>
  </form>

  <div class="erow">
    <div class="rowtitle">Actions:</div>
    <div class="rowtext">
      <%=link_to 'Purge tracking table [DANGER!!!]',"/blocks/reset",data: {confirm: "Delete all firewall data: This will remove all blocks and potentially force valid users to re-verify. Are you sure?"}, remote: true,  :id => 'view', :onclick => "linkHandler('reset')"%>
    </div>
  </div>

  <div class="name_pagination"> <%= will_paginate(@blocks) %></div>

  <table id="blocks">
    <tr>
      <th>Action</th>
      <th>IP</th>
      <th>First Seen</th>
      <th>Last Seen</th>
      <th>Human</th>
      <th>Suspect</th>
      <th>Bot</th>
      <th>Hits</th>
      <th>JS ratio</th>
      <th>Suspect hits</th>
      <th>User Agent</th>
    </tr>
    <% @blocks.each do |block| %>
      <tr>
        <td>
           <%=link_to 'Delete',"/blocks/#{block.id}/delete",remote: true,  :id => 'view', :onclick => "linkHandler('delete')"%>
           <%=link_to 'Human',"/blocks/#{block.id}/human",remote: true,  :id => 'view', :onclick => "linkHandler('human')"%>
           <%=link_to 'Robot',"/blocks/#{block.id}/robot",remote: true,  :id => 'view', :onclick => "linkHandler('robot')"%>
        <td><%= block.user_ip %></td> 
        <td><%= block.created_at %></td> 
        <td><%= block.updated_at %></td> 
        <td><%= block.confirmed_human %></td> 
        <td><%= block.suspected_bot %></td> 
        <td><%= block.confirmed_bot %></td> 
        <td><%= block.access_count %></td> 
        <td><%= 1.0*(block.js_count/block.access_count) %></td> 
        <td><%= block.suspicious_access_count %></td>
        <td><%= block.user_agent %></td>
      </tr>
    <% end %>
  </table>
  <div class="name_pagination"> <%= will_paginate(@blocks) %></div>

</div>
<script>
document.getElementById('actionbar-full').innerHTML=document.getElementById('actionbar').innerHTML;
site_smaller_map();

</script>

